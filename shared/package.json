{
    "name": "fuesim-digital-shared",
    "version": "0.11.1",
    "type": "module",
    "main": "./dist/index.js",
    "esnext": "./dist/index.js",
    "module": "./dist/index.js",
    "es2015": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "/dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "watch": "tsc -p tsconfig.build.json --watch",
        "lint": "eslint --max-warnings 0 \"./**/*.{ts,js,yml,html}\"",
        "lint:fix": "eslint --fix \"./**/*.{ts,js,yml,html}\"",
        "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage --verbose --ci",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage --verbose --no-cache",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --verbose --watch"
    },
    "private": true,
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "~24.13.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": "~11.6.2",
            "onFail": "error"
        }
    },
    "dependencies": {
        "@noble/hashes": "^1.7.1",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "immer": "^10.1.1",
        "lodash-es": "^4.17.23",
        "papaparse": "^5.5.3",
        "rbush": "^4.0.1",
        "rbush-knn": "^4.0.0",
        "reflect-metadata": "^0.2.2",
        "uuid": "^11.1.0",
        "zod": "^4.1.13"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.0",
        "@eslint/js": "^9.36.0",
        "@types/jest": "^30.0.0",
        "@types/lodash-es": "^4.17.12",
        "@types/papaparse": "^5.5.2",
        "@types/rbush": "^4.0.0",
        "@types/validator": "^13.12.3",
        "eslint": "^9.36.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-import": "~2.31.0",
        "eslint-plugin-unicorn": "^56.0.1",
        "jest": "^30.2.0",
        "jest-extended": "^4.0.2",
        "socket.io": "^4.8.3",
        "ts-jest": "^29.4.5",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.55.0"
    },
    "exports": {
        ".": {
            "node": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "overrides": {
        "@istanbuljs/load-nyc-config": {
            "js-yaml": "^4.1.1"
        }
    }
}
