{
    "name": "fuesim-digital-benchmark",
    "version": "0.11.1",
    "type": "module",
    "scripts": {
        "lint": "eslint --max-warnings 0 \"./**/*.{ts,js,yml,html}\"",
        "lint:fix": "eslint --fix \"./**/*.{ts,js,yml,html}\"",
        "benchmark:linux-macos": "NODE_ENV=production tsx src/app.ts",
        "benchmark:windows": "set NODE_ENV=production&& tsx src/app.ts",
        "benchmark": "(pwd && npm run benchmark:linux-macos) || npm run benchmark:windows"
    },
    "private": true,
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "~24.13.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": "~11.6.2",
            "onFail": "error"
        }
    },
    "dependencies": {
        "fuesim-digital-shared": "file:../shared",
        "immer": "^10.1.1",
        "lodash-es": "^4.17.23"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.0",
        "@eslint/js": "^9.36.0",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^22.14.0",
        "eslint": "^9.36.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-import": "~2.31.0",
        "eslint-plugin-unicorn": "^56.0.1",
        "tsx": "^4.19.3",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.55.0"
    },
    "overrides": {
        "@istanbuljs/load-nyc-config": {
            "js-yaml": "^4.1.1"
        }
    }
}
